# Ignore tout par défaut
/*

# Autoriser les dossiers structurels
!/infra/
!/scripts/
!/.github/

# Autoriser les fichiers racines importants
!.gitignore
!.env.example
!README.md
!RECOVERY.md

# --- Règles spécifiques pour /infra ---
# Ignorer TOUT dans infra sauf les docker-compose et Dockerfiles
/infra/**
!/infra/**/
!/infra/**/docker-compose.yml
!/infra/**/Dockerfile
!/infra/**/*.sh
!/infra/monitoring/config/prometheus/prometheus.yml
!/infra/monitoring/config/homepage/*.yaml

# --- Règles spécifiques pour /scripts ---
/scripts/**
!/scripts/**/
!/scripts/**/*.go
!/scripts/go.mod
!/scripts/go.sum
!/scripts/Dockerfile
!/scripts/**/*.sh
!/scripts/config_share.json
!/scripts/storage_policy.json

# --- Exclusions Globales (Sécurité) ---
.env
*.db
*.db-*
*.log
*.gpg
*.tar.gz
*.zip
*.pid
bin/
**/node_modules/
**/venv/
**/ai-env/
**/config/
**/data/
**/Definitions/
**/asp/
**/*.pid
**/*.txt
**/*.pem

# Binaires compilés
scripts/myflixbot*
scripts/main
scripts/mkvcleaner
