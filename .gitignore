# Ignore tout par défaut
/*

# Autoriser les dossiers structurels
!/infra/
!/scripts/
!/.github/

# Autoriser les fichiers racines importants
!.gitignore
!.env.example
!README.md
!RECOVERY.md

# --- Règles spécifiques pour /.github ---
!/.github/workflows/
!/.github/workflows/*.yml

# --- Règles spécifiques pour /infra ---
/infra/**
!/infra/**/
!/infra/**/docker-compose.yml
!/infra/**/docker-monitoring.yml
!/infra/**/Dockerfile
!/infra/**/*.sh
!/infra/ai/maintenance/restore_app_configs.sh
!/infra/crontab.txt
!/infra/monitoring/config/prometheus/prometheus.yml
!/infra/monitoring/config/homepage/*.yaml

# --- Règles spécifiques pour /scripts ---
/scripts/**
!/scripts/**/
!/scripts/**/*.go
!/scripts/go.mod
!/scripts/go.sum
!/scripts/Dockerfile
!/scripts/.dockerignore
!/scripts/**/*.sh
!/scripts/config_share.json
!/scripts/storage_policy.json

# --- Exclusions Globales (Sécurité & Nettoyage) ---
.env
*.db
*.db-*
*.log
*.gpg
*.tar.gz
*.zip
*.pid
bin/
go/
**/node_modules/
**/venv/
**/ai-env/
**/*.pid
**/*.pem
**/secrets/
**/backups_automated/
**/backups_emergency/

# On ignore spécifiquement les dossiers de données et config dans infra
/infra/**/config/
/infra/**/data/
/infra/**/Definitions/
/infra/**/asp/

# Exceptions pour les fichiers de config autorisés explicitement ci-dessus
!/infra/monitoring/config/prometheus/prometheus.yml
!/infra/monitoring/config/homepage/*.yaml

# Binaires compilés
scripts/myflixbot*
scripts/main
scripts/mkvcleaner
